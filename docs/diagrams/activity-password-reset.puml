@startuml IMEP_Activity_PasswordReset

skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam ActivityBorderColor #E67E22
skinparam ActivityBackgroundColor #FEF9E7
skinparam ActivityDiamondBorderColor #E74C3C
skinparam ActivityDiamondBackgroundColor #FADBD8
skinparam ActivityStartColor #1A5276
skinparam ActivityEndColor #1A5276
skinparam swimlaneBorderColor #BDC3C7
skinparam swimlaneBackgroundColor #FDFEFE

title IMEP — Activity Diagram: Password Reset Process

|User|
start

:Click "Forgot Password"\non the login page;

:Enter registered email address;

:Submit\n(POST /api/auth/forgot-password);

|Backend API|

:Find user by email\n(User.findOne({ email }));

if (User exists in DB?) then (No)
  note right
    Always return 200 even when
    user not found — prevents
    email enumeration attacks
  end note
  :Return 200 (generic success message);

  |User|
  :See "If that email is registered,\nyou'll receive a link shortly";
  stop

else (Yes)
  :Generate cryptographic reset token\n(crypto.randomBytes(32).toString('hex'));
  :Hash token (SHA-256) and store in\nUser.resetPasswordToken;
  :Set User.resetPasswordExpiry = now + 1 hour;
  :Save user document;
endif

|Email Service (Nodemailer)|

:Compose password reset email:\n• To: user's email address\n• Link: /reset-password?token=<raw_token>\n• Expiry warning: "Link valid for 1 hour";

:Send via Gmail SMTP (transporter.sendMail);

|User|

:Check inbox;
:Click the password reset link in email;

:Enter new password;
:Confirm new password;

:Submit\n(POST /api/auth/reset-password\n{ token, newPassword });

|Backend API|

:Hash the incoming token (SHA-256);
:Find user where:\n  resetPasswordToken = hashedToken\n  AND resetPasswordExpiry > now;

if (Token valid and not expired?) then (No)
  :Return 400\n"Password reset link is invalid\nor has expired";

  |User|
  :Show error message;
  :Click "Forgot Password" to try again;
  stop

else (Yes)
  :bcrypt.hash(newPassword, 12);
  :Update user.password = hashedPassword;
  :Clear resetPasswordToken = undefined;
  :Clear resetPasswordExpiry = undefined;
  :Delete all active Sessions\n(invalidate all logged-in devices);
  :Return 200 "Password reset successful";
endif

|User|

:Redirect to Login page;

:Login with the new password;

stop

@enduml
